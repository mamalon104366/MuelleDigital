# Copia este archivo a ".env" y completa los valores reales.

# Puerto del servidor
PORT=4000

# Cadena de conexión de NeonDB (PostgreSQL)
# Formato: postgresql://USUARIO:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# Secreto para firmar los JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# URL del frontend permitida por CORS (en producción pon la de Vercel)
CLIENT_URL=http://localhost:5173

# --- Stripe (modo TEST) — obtén las claves en https://dashboard.stripe.com/test/apikeys ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Secreto del webhook (de `stripe listen` o del dashboard). Opcional en local.
STRIPE_WEBHOOK_SECRET=
# Comisión de la plataforma (modelo marketplace), en porcentaje
COMISION_PORCENTAJE=10
# Moneda de los precios (ISO 4217)
MONEDA=cop
